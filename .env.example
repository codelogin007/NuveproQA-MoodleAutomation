# Copy to .env and fill in. .env is git-ignored.

# Target Moodle instance (a RUNNING site — tests execute against this)
MOODLE_BASE_URL=https://moodle-test.nuvepro.com

# UI login credentials for role-based tests
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASS=change-me
MOODLE_STUDENT_USER=student1
MOODLE_STUDENT_PASS=change-me

# Moodle Web Services token (Site admin > Server > Web services > Manage tokens)
# Used by helpers/ApiClient to seed test data (create user + enrol) via REST.
MOODLE_WS_TOKEN=change-me

# CloudLabs (provider) API — SEPARATE system from Moodle. Used to extend an existing lab's
# duration so long/existing-lab tests don't expire mid-run. Auth = admin login/pwd -> token.
CLOUDLABS_GATEWAY_URL=
CLOUDLABS_LOGIN_URL=
CLOUDLABS_ADMIN_USER=
CLOUDLABS_ADMIN_PASS=

# Mail trap (for email-delivery assertions: reports, forgot-password, results)
MAILTRAP_API_URL=http://localhost:8025/api/v2
MAILTRAP_API_TOKEN=

# Provisioning mode: stub | real  (stub = fast UI suite, real = capped cloud test tenant)
PROVISIONING_MODE=stub

# Existing activity cmids to test against (Option B — reuse pre-created activities).
# Get from the URL when you open the activity: .../mod/cloudlabs/view.php?id=<cmid>
# Course used by activity-creation tests (PG-1). From the course URL ?id=<n>.
COURSE_ID=
PLAYGROUND_CMID=
GUIDED_CMID=
ASSESSMENT_CMID=
# Optional gap-case activities (scenarios skip until set):
PLAYGROUND_VM_CMID=
PLAYGROUND_CATALOG_CMID=
PLAYGROUND_BADTEMPLATE_CMID=
PLAYGROUND_UNLIMITED_CMID=

# Playwright
# HEADLESS=false shows the browser; true hides it. Override per-run with -Dheadless=false.
HEADLESS=true
# SLOWMO_MS slows each action (ms) so headed runs are easy to follow. Override with -Dslowmo=500.
SLOWMO_MS=0
DEFAULT_TIMEOUT_MS=15000

# Assessment (challenge) activity-creation config (optional; used when tests CREATE assessments).
# The submit-assessment evaluation script path (runs in the engine against the lab account):
ASSESSMENT_SCRIPT_URL=
# Lab template to select (plan/team ride along with the template definition, e.g.
# "aws.Account.Clab_ACCOUNT_VPAT Testing" = Plan 777 / Team 90 / catalog aws.Account.Clab):
ASSESSMENT_LAB_TEMPLATE=
